# Blockfrost API proxy configuration
# Server-side URL for Blockfrost API (used by delegation proxy at /api/bf/)
# Default: https://cardano-mainnet.blockfrost.io/api/v0
# In-cluster: http://blockfrost-platform-mainnet.cardano.svc.cluster.local:3000
BLOCKFROST_URL=https://cardano-mainnet.blockfrost.io/api/v0

# Blockfrost project ID (only needed for hosted Blockfrost, not self-hosted)
BLOCKFROST_PROJECT_ID=

# Koios API base URL (used by pool stats endpoints)
# Default: https://koios.tosidrop.me/api/v1
KOIOS_API_URL=https://koios.tosidrop.me/api/v1

# SQLite database path (leaderboard + reward logs)
# In production, use a persistent volume mount
DB_PATH=/tmp/starforge.db

# Vending machine (vm.adaseal.eu) for NIGHT token rewards
VENDING_MACHINE_URL=https://vm.adaseal.eu/api.php
VENDING_MACHINE_API_KEY=
NIGHT_POLICY_ID=0691b2fecca1ac4f53cb6dfb00b7013e561d1f34403b957cbb5af1fa

# Prometheus server URL (used by /metrics page for live Cardano node metrics)
# In-cluster: http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
# Via Tailscale: http://k3s-prometheus.boston-woodpecker.ts.net:9090
# Leave empty to disable metrics page data
PROMETHEUS_URL=

# Cloudflare Turnstile (bot protection for game rewards)
# Get keys at: https://dash.cloudflare.com → Turnstile → Add Widget
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
